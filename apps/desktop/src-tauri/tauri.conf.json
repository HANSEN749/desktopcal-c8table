{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DesktopCal",
  "version": "0.1.0",
  "identifier": "cn.desktopcal.mvp",
  "build": {
    "beforeDevCommand": "npm --workspace @desktopcal/web run dev",
    "beforeBuildCommand": "npm --workspace @desktopcal/web run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "DesktopCal",
        "label": "main",
        "width": 1080,
        "height": 760,
        "minWidth": 920,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "resizable": true,
        "center": true,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": []
  }
}
